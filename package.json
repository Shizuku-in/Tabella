{
  "name": "tabella",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "prepare": "lefthook install",
    "dev:web": "pnpm --filter @tabella/web dev",
    "build:web": "pnpm --filter @tabella/web build",
    "lint:web": "pnpm --filter @tabella/web lint",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.3"
  }
}
