# PostgreSQL Connection String (Required)
DATABASE_URL=postgres://postgres:password@localhost/tabella

# Server listening address (Optional, default: 127.0.0.1:8787)
# TABELLA_LISTEN_ADDR=127.0.0.1:8787

# Storage Paths (Optional)
# TABELLA_MEDIA_ROOT=var/media
# TABELLA_TEMP_ROOT=var/tmp

# Session and Security (Optional)
# TABELLA_SESSION_COOKIE_NAME=tabella_session
# TABELLA_SESSION_TTL_HOURS=720
# TABELLA_SECURE_COOKIES=false

# Default Admin Credentials for Bootstrapping (Optional)
# TABELLA_BOOTSTRAP_ADMIN_USERNAME=admin
# TABELLA_BOOTSTRAP_ADMIN_PASSWORD=admin
